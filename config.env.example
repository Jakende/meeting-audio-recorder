# Meeting Audio Recorder Configuration
# This file can be edited to customize your recording settings
# All settings can also be overridden via environment variables

# Audio Devices
BLACKHOLE_DEVICE="BlackHole 2ch"
MIC_DEVICE="MacBook Pro Microphone"

# Output Settings
OUTPUT_DIR="$HOME/..."

# Audio Parameters
SAMPLE_RATE="48000"
BITRATE="192k"
AUDIO_CODEC="aac"
CONTAINER_FORMAT="m4a"

# Optional: Maximum recording duration in seconds (empty = unlimited)
# MAX_DURATION=""

# Optional: Enable auto-split for long recordings (true/false)
# AUTO_SPLIT="false"
